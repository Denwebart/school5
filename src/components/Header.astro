<!-- Wrapper to prevent layout shift (FOUC) when header becomes fixed -->
<div
      x-data="{
  isFixed: false,
  openMenu: false,
  openContacts: false,
  isAnimating: false,
  isInitialized: false,
  init() {
    // Set the initial state without animation
    this.isFixed = window.scrollY > 10;

    this.$watch('isFixed', (value, oldValue) => {
      // Animation only after full initialization and when there is a real change
      if (this.isInitialized && value === true && oldValue === false) {
        this.isAnimating = true;
        setTimeout(() => {
          this.isAnimating = false;
        }, 500);
      }
    });

    // Mark as initialized in the next tick
    this.$nextTick(() => {
      this.isInitialized = true;
    });

    this.$watch('openMenu', value => document.body.classList.toggle('overflow-hidden', value));
  }
}"
      @scroll.window="isFixed = window.scrollY > 10"
      @keydown.escape.window="openMenu = false; openContacts = false"
    >
